{
  "name": "studybond",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build && node scripts/prepare-standalone.mjs",
    "start": "node scripts/start-standalone.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run && npm run test:contract",
    "test:watch": "vitest",
    "test:contract": "cargo test --manifest-path contracts/study_bond_escrow/Cargo.toml",
    "contract:build": "stellar contract build --manifest-path contracts/study_bond_escrow/Cargo.toml --out-dir contracts/study_bond_escrow/dist --optimize",
    "contract:bindings": "stellar contract bindings typescript --wasm contracts/study_bond_escrow/dist/study_bond_escrow.wasm --output-dir src/lib/stellar/generated-client --overwrite",
    "contract:deploy:testnet": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/deploy-contract.ps1",
    "wallets:create": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-test-wallets.ps1",
    "wallets:fund": "dotenv -e .env -- tsx scripts/fund-test-wallets.ts",
    "wallets:proofs": "dotenv -e .env -- tsx scripts/generate-wallet-proofs.ts",
    "wallets:verify": "dotenv -e .env -- tsx scripts/verify-test-wallets.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "dotenv -e .env -- tsx scripts/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@stellar/freighter-api": "^6.0.0",
    "@stellar/stellar-sdk": "^16.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "seed": "dotenv -e .env -- tsx scripts/seed.ts"
  }
}
